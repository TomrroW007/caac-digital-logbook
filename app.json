{
    "expo": {
        "name": "CAAC Digital Logbook",
        "slug": "caac-digital-logbook",
        "version": "1.5.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0A0F1E"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "web": {
            "bundler": "metro",
            "favicon": "./assets/favicon.png",
            "name": "Pilot Logbook 飞行记录本",
            "shortName": "Pilot",
            "display": "standalone",
            "backgroundColor": "#0A0F1E",
            "themeColor": "#0A0F1E"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.caac.digitallogbook"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0A0F1E"
            },
            "package": "com.caac.digitallogbook"
        },
        "jsEngine": "hermes",
        "extra": {
            "workerUrl": "https://caac-logbook-worker.caac-logbook.workers.dev"
        },
        "plugins": []
    }
}