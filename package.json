{
  "name": "caac-digital-logbook",
  "version": "0.1.0",
  "description": "CAAC CCAR-61 compliant digital pilot logbook — offline-first React Native (Expo) app.",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "npx expo export -p web",
    "serve:web": "npx serve dist"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@expo/metro-runtime": "~4.0.1",
    "@nozbe/watermelondb": "^0.27.1",
    "@nozbe/with-observables": "^1.6.0",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.8",
    "expo-file-system": "~18.0.12",
    "expo-print": "~14.0.3",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.9",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "^0.19.13",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.18.5/xlsx-0.18.5.tgz"
  }
}